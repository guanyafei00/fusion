# Fusion LLM Gateway
FUSION_LLM_BASE_URL=https://openrouter.ai/api/v1
FUSION_LLM_API_KEY=your-api-key-here

# Model roster (comma-separated)
FUSION_PANEL_MODELS=qwen/qwen3-235b-a14b-instruct,google/gemma-3-27b-it,mistralai/mistral-small-3.1-24b-instruct
FUSION_JUDGE_MODEL=openai/gpt-oss-120b
FUSION_SYNTH_MODEL=deepseek/deepseek-chat-v3-0324

# Optional: Tavily search API
FUSION_TAVILY_KEY=

# Timeout
FUSION_LLM_TIMEOUT=90
FUSION_FETCH_TIMEOUT=25

# Rate limit (requests per minute)
FUSION_RPM_LIMIT=20

# Auth token (optional, for self-hosted)
FUSION_AUTH_TOKEN=

# Cache directory
FUSION_CACHE_DIR=/tmp/fusion_cache
